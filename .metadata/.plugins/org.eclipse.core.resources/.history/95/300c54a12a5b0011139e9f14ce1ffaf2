/******************************************************************************
 * CLI - set_id command
 *   사용법: set_id <1~4>
 *   NVM3에 device_id 영구 저장 → reset 후 app_init.c 가 자동 로드.
 *   최초 1회만 실행하면 됨.
 *****************************************************************************/
void cli_set_device_id(sl_cli_command_arg_t *arguments)
{
  uint8_t new_id = sl_cli_get_argument_uint8(arguments, 0);

  if (new_id < 1 || new_id > 4) {
    app_log_error("set_id: invalid value=%d (valid range: 1~4)\n", new_id);
    return;
  }

  Ecode_t ecode = nvm3_writeData(nvm3_defaultHandle,
                                 (nvm3_ObjectKey_t)DEVICE_ID_NVM3_KEY,
                                 &new_id,
                                 sizeof(new_id));

  if (ecode == ECODE_NVM3_OK) {
    my_device_id = new_id;
    app_log_info("Device ID set to %d and saved to NVM3.\n", new_id);
    app_log_info("Please reboot (CLI: reset) to apply.\n");
  } else {
    app_log_error("NVM3 write FAILED: 0x%lX\n", ecode);
  }
}

/******************************************************************************
 * CLI - join command
 *****************************************************************************/
void cli_join(sl_cli_command_arg_t *arguments)
{
  EmberStatus status;
  EmberNetworkParameters parameters;
  uint16_t channel = sl_cli_get_argument_uint8(arguments, 0);

  if (check_channel(channel) == false) return;

  MEMSET(&parameters, 0, sizeof(EmberNetworkParameters));
  parameters.radioTxPower = tx_power;
  parameters.radioChannel = channel;

  if (sl_cli_get_argument_count(arguments) > 1) {
    parameters.panId = sl_cli_get_argument_uint16(arguments, 1);
  } else {
    parameters.panId = SL_SENSOR_SINK_PAN_ID;
  }

  emberClearSelectiveJoinPayload();
  status = emberJoinNetwork(EMBER_STAR_END_DEVICE, &parameters);
  app_log_info("join end device: status 0x%02X\n", status);
}

