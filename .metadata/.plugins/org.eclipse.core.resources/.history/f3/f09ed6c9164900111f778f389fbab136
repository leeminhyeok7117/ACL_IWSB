/**************************************************************************//**
 * Incoming message callback
 *
 * ╔══════════════════════════════════════════════════════════════════╗
 * ║ 두 가지 메시지를 처리:                                        ║
 * ║ 1. CUSTOM_ENDPOINT (0x02) → Master의 OTA 준비 명령           ║
 * ║ 2. SL_SENSOR_SINK_ENDPOINT → 일반 데이터 (Slave→Master 응답) ║
 * ╚══════════════════════════════════════════════════════════════════╝
 *****************************************************************************/
void emberAfIncomingMessageCallback(EmberIncomingMessage *message)
{
  // ─── Master로부터 OTA 준비 명령 수신 ───
  if (message->endpoint == CUSTOM_ENDPOINT
      && message->length >= 1
      && message->payload[0] == CUSTOM_MSG_PREPARE_OTA) {
    handle_ota_prepare_msg(message);
    return;
  }

  // ─── 기타 메시지 처리 (필요시 추가) ───
  app_log_info("RX from 0x%04X: ep=%d, len=%d\n",
               message->source, message->endpoint, message->length);
}

