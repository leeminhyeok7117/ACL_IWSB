static bool     ota_prepare_done = false;
static uint8_t  ota_expected_tag = 0;
static uint32_t ota_expected_size = 0;

/// Join 재시도 타이머
static uint32_t join_retry_timer = 0;

/// 센서 리포트 타이머
static uint32_t sensor_report_timer = 0;

