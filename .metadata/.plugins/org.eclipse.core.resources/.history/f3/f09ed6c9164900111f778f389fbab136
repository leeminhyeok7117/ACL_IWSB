/**************************************************************************//**
 * Stack status callback — 네트워크 상태 변화 처리
 *
 * ╔══════════════════════════════════════════════════════════════════╗
 * ║ 핵심: EMBER_NETWORK_UP 수신 시 network_joined = true          ║
 * ║       EMBER_NETWORK_DOWN 시 자동 재접속 시도                  ║
 * ║ OTA 후 리부트 → NVM 복원 → EMBER_NETWORK_UP 자동 발생        ║
 * ╚══════════════════════════════════════════════════════════════════╝
 *****************************************************************************/
void emberAfStackStatusCallback(EmberStatus status)
{
  switch (status) {
    case EMBER_NETWORK_UP:
      app_log_info("Network UP. NodeID=0x%04X\n", emberGetNodeId());
      network_joined = true;
      join_in_progress = false;
      break;

    case EMBER_NETWORK_DOWN:
      app_log_info("Network DOWN.\n");
      network_joined = false;
      join_in_progress = false;
      // 자동 재접속 타이머 시작
      join_retry_timer = sl_sleeptimer_get_tick_count();
      break;

    default:
      app_log_info("Stack status: 0x%02X\n", status);
      break;
  }
}

/**************************************************************************//**
 * Tick callback — 메인 루프
 *****************************************************************************/
void emberAfTickCallback(void)
{
  // ── LED: 네트워크 상태 표시 ──
  if (emberStackIsUp()) {
    sl_led_turn_on(&sl_led_led0);
  } else {
    sl_led_turn_off(&sl_led_led0);
  }

  // ── 네트워크 미접속 시 자동 재접속 ──
  if (!network_joined && !join_in_progress) {
    uint32_t elapsed = sl_sleeptimer_tick_to_ms(
                         sl_sleeptimer_get_tick_count() - join_retry_timer);
    if (elapsed > JOIN_RETRY_INTERVAL_MS) {
      app_log_info("Retrying join...\n");
      try_rejoin();
      join_retry_timer = sl_sleeptimer_get_tick_count();
    }
  }

  // ╔══════════════════════════════════════════════════════════════════╗
  // ║ [확장성] 센서 데이터 주기 전송 — Slave별 센서에 맞게 수정     ║
  // ║ 현재는 기본 sensor-sink 동작 유지.                            ║
  // ║ 실제 큐브위성 센서(온도, 자이로 등)에 맞게 교체 필요.         ║
  // ╚══════════════════════════════════════════════════════════════════╝
  // (기존 센서 리포트 로직은 sl_sensor_sink 컴포넌트에서 처리)
}

/**************************************************************************//**
 * [OTA Client Callback] 새 이미지 수신 시작 알림
 *
 * Master가 distribution을 시작하면 호출됨.
 * TRUE 반환 → 수신 수락, FALSE → 거부.
 *
 * ╔══════════════════════════════════════════════════════════════════╗
 * ║ [확장성] imageTag로 이 Slave용 펌웨어인지 구분 가능:          ║
 * ║   0xAA = 공통 펌웨어 (모든 Slave)                             ║
 * ║   0x01 = Slave 1 전용                                         ║
 * ║   0x02 = Slave 2 전용                                         ║
 * ║   0x03 = Slave 3 전용                                         ║
 * ║   0x04 = Slave 4 전용                                         ║
 * ║ 지금은 모든 tag를 수락. 필요시 필터링 추가.                    ║
 * ╚══════════════════════════════════════════════════════════════════╝
 *****************************************************************************/
bool emberAfPluginOtaUnicastBootloaderClientNewIncomingImageCallback(
  EmberNodeId serverId,
  uint8_t imageTag,
  uint32_t imageSize,
  uint32_t *startIndex)
{
  app_log_info("OTA: New image from server 0x%04X, tag=0x%02X, size=%lu\n",
               serverId, imageTag, imageSize);

  // ╔═══════════════════════════════════════════════════╗
  // ║ [확장성] tag 필터링 예시 (필요시 활성화):        ║
  // ║ if (imageTag != MY_SLAVE_TAG                     ║
  // ║     && imageTag != 0xAA) {                       ║
  // ║   app_log_info("Tag mismatch, rejecting.\n");    ║
  // ║   return false;                                  ║
  // ║ }                                                ║
  // ╚═══════════════════════════════════════════════════╝

  ota_expected_tag  = imageTag;
  ota_expected_size = imageSize;

  // startIndex를 0으로 설정 → 처음부터 수신
  // resume 기능 사용 시 bootloader에서 마지막 offset 읽어서 설정 가능
  *startIndex = 0;

  return true;  // 수신 수락
}

/**************************************************************************//**
 * [OTA Client Callback] 이미지 세그먼트 수신
 *
 * 수신된 세그먼트를 bootloader storage slot 0에 기록.
 *****************************************************************************/
void emberAfPluginOtaUnicastBootloaderClientIncomingImageSegmentCallback(
  EmberNodeId serverId,
  uint32_t startIndex,
  uint32_t endIndex,
  uint8_t imageTag,
  uint8_t *imageSegment)
{
  (void)serverId;
  (void)imageTag;

  uint32_t len = endIndex - startIndex + 1;

  int32_t ret = bootloader_writeStorage(0, startIndex, imageSegment, len);
  if (ret != BOOTLOADER_OK) {
    app_log_error("OTA: writeStorage FAIL at %lu: 0x%lX\n", startIndex, ret);
  }
}

/**************************************************************************//**
 * [OTA Client Callback] 이미지 다운로드 완료
 *****************************************************************************/
void emberAfPluginOtaUnicastBootloaderClientImageDownloadCompleteCallback(
  EmberAfOtaUnicastBootloaderStatus status,
  uint8_t imageTag,
  uint32_t imageSize)
{
  if (status == EMBER_OTA_UNICAST_BOOTLOADER_STATUS_SUCCESS) {
    app_log_info("OTA: Download COMPLETE. tag=0x%02X, size=%lu\n",
                 imageTag, imageSize);

    // 이미지 검증 (선택사항이지만 권장)
    // bootloader_verifyImage() 사용 가능

    // 부트로드할 이미지 지정
    int32_t ret = bootloader_setImageToBootload(0);
    if (ret == BOOTLOADER_OK) {
      app_log_info("OTA: Image set to bootload from slot 0.\n");
    } else {
      app_log_error("OTA: setImageToBootload FAIL: 0x%lX\n", ret);
    }
  } else {
    app_log_error("OTA: Download FAILED, status=0x%02X\n", status);
  }
}

/**************************************************************************//**
 * [OTA Client Callback] 서버로부터 부트로드 요청 수신
 *
 * Master가 bootload를 요청하면 호출됨.
 * TRUE 반환 → 부트로드 수락 (delay 후 재부팅)
 * FALSE → 거부
 *
 * ╔══════════════════════════════════════════════════════════════════╗
 * ║ TRUE 반환 후 delay(Master가 설정한 2000ms) 경과 시            ║
 * ║ bootloader_rebootAndInstall() 자동 실행됨 (플러그인 내부)     ║
 * ║ → 재부팅 → 새 펌웨어 적용                                    ║
 * ║ → emberNetworkInit() → NVM 복원 → 자동 재접속                ║
 * ╚══════════════════════════════════════════════════════════════════╝
 *****************************************************************************/
bool emberAfPluginOtaUnicastBootloaderClientBootloadRequestCallback(
  uint8_t imageTag,
  uint32_t firmwareTag,
  EmberNodeId serverId)
{
  (void)firmwareTag;

  app_log_info("OTA: Bootload request from 0x%04X, tag=0x%02X. ACCEPTING.\n",
               serverId, imageTag);

  // 부트로드 수락 → delay 후 자동 재부팅
  return true;
}

