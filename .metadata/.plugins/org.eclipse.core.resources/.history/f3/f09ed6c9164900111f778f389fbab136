/// Master → Slave 커스텀 메시지 (Master의 app_process.c와 동일 값)
#define CUSTOM_MSG_PREPARE_OTA   0xF0
#define CUSTOM_MSG_PREPARE_ACK   0xF1
#define CUSTOM_ENDPOINT          0x02

/// Join 재시도 타이밍
#define JOIN_RETRY_INTERVAL_MS   5000

// ╔══════════════════════════════════════════════════════════════════╗
// ║ [확장성] Slave별 센서 리포트 주기를 다르게 할 수 있음          ║
// ║ Slave 1: 1000ms, Slave 2: 2000ms 등                           ║
// ╚══════════════════════════════════════════════════════════════════╝
#define SENSOR_REPORT_INTERVAL_MS  1000

