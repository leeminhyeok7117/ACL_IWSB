/**************************************************************************//**
 * sweep_tx_tick() — emberAfTickCallback()에서 매 틱 호출
 *
 * 상태 흐름:
 *
 *   SWEEP_IDLE ─(SWEEP_START 수신)─→ SWEEP_WAIT_START
 *     ↓ (SWEEP_START_DELAY_MS 경과)
 *   SWEEP_TX_NEXT ←──────────────── SWEEP_TX_ACTIVE
 *     ↓ (채널 전환+CW 시작)          ↑ (dwell time 미경과)
 *   SWEEP_TX_ACTIVE                  │
 *     ↓ (dwell time 경과)            │
 *     ├─ 채널 남음 ───→ idx++ ───→ SWEEP_TX_NEXT
 *     └─ 마지막 ────→ SWEEP_DONE
 *                       ↓
 *                    SWEEP_IDLE (Connect 복구 + DONE 메시지)
 *****************************************************************************/
static void sweep_tx_tick(void)
{
  if (sweep_state == SWEEP_IDLE) {
    return;
  }

  uint32_t elapsed_ms = sl_sleeptimer_tick_to_ms(
    sl_sleeptimer_get_tick_count() - sweep_tick_start);

  switch (sweep_state) {

    // ── 시작 딜레이 대기 ──
    case SWEEP_WAIT_START: {
      if (elapsed_ms >= SWEEP_START_DELAY_MS) {
        app_log_info("SWEEP: Starting RF sweep (%d ch, %d ms/ch)\n",
                     SWEEP_FREQ_COUNT, SWEEP_DWELL_MS);

        // Connect 스택의 RAIL 사용을 중단
        // (진행 중인 TX/RX 즉시 취소)
        RAIL_Idle(rail_handle, RAIL_IDLE_ABORT, true);

        sweep_freq_idx = 0;
        sweep_state    = SWEEP_TX_NEXT;
      }
      break;
    }

    // ── 다음 채널 전환 + CW 시작 ──
    case SWEEP_TX_NEXT: {
      if (sweep_freq_idx >= SWEEP_FREQ_COUNT) {
        sweep_state = SWEEP_DONE;
        break;
      }
      sweep_tx_start_channel(sweep_freq_idx);
      sweep_tick_start = sl_sleeptimer_get_tick_count();
      sweep_state      = SWEEP_TX_ACTIVE;
      break;
    }

    // ── CW 송신 유지 (dwell time 대기) ──
    case SWEEP_TX_ACTIVE: {
      if (elapsed_ms >= SWEEP_DWELL_MS) {
        RAIL_StopTxStream(rail_handle);

        app_log_info("SWEEP: [%02lu] %lu MHz done\n",
                     sweep_freq_idx,
                     sweep_freq_hz[sweep_freq_idx] / 1000000UL);

        sweep_freq_idx++;
        sweep_state = SWEEP_TX_NEXT;
      }
      break;
    }

    // ── 완료 처리 ──
    case SWEEP_DONE: {
      app_log_info("SWEEP: Complete. Restoring Connect.\n");

      // Connect RF 복구
      sweep_tx_stop_and_restore();

      // Master에 완료 알림
      send_sweep_done_msg(sweep_master_id);

      sweep_master_id = EMBER_NULL_NODE_ID;
      sweep_state     = SWEEP_IDLE;
      break;
    }

    default:
      sweep_state = SWEEP_IDLE;
      break;
  }
}

/**************************************************************************//**
 * sweep_tx_start_channel() — 주파수 설정 + CW 송신 시작
 *
 * RAIL API:
 *   RAIL_OverrideDebugFrequency(): 채널 0의 주파수를 임의값으로 오버라이드
 *   RAIL_StartTxStream():          CW 반송파 연속 송신 시작
 *
 * @param freq_idx  sweep_freq_hz[] 배열 인덱스
 *****************************************************************************/
static void sweep_tx_start_channel(uint32_t freq_idx)
{
  uint32_t freq = sweep_freq_hz[freq_idx];

  RAIL_Status_t ret;

  // 주파수 오버라이드
  ret = RAIL_OverrideDebugFrequency(rail_handle, freq);
  if (ret != RAIL_STATUS_NO_ERROR) {
    // 실패 가능 원인: 주파수가 칩 synthesizer 튜닝 범위 밖
    app_log_error("SWEEP: OverrideFreq(%lu Hz) FAIL: 0x%02X\n", freq, ret);
  }

  // CW (Carrier Wave) 송신 시작
  ret = RAIL_StartTxStream(rail_handle, 0, RAIL_STREAM_CARRIER_WAVE);
  if (ret != RAIL_STATUS_NO_ERROR) {
    app_log_error("SWEEP: StartTxStream FAIL @ %lu MHz: 0x%02X\n",
                  freq / 1000000UL, ret);
  }
}

/**************************************************************************//**
 * sweep_tx_stop_and_restore() — CW 중단 + Connect RF 상태 복구
 *
 * 순서:
 *   1. CW 스트림 중단 (혹시 남아있을 경우 대비)
 *   2. 주파수 오버라이드 해제 (0 전달 → 원래 채널 주파수 복구)
 *   3. 채널 0 RX 진입 → Connect 스택 자동 재접수
 *****************************************************************************/
static void sweep_tx_stop_and_restore(void)
{
  RAIL_StopTxStream(rail_handle);
  RAIL_OverrideDebugFrequency(rail_handle, 0);
  RAIL_StartRx(rail_handle, 0, NULL);

  app_log_info("SWEEP: RF restored (ch0 RX mode).\n");
}

/**************************************************************************//**
 * send_sweep_done_msg() — Master에 스윕 완료 알림 전송
 *
 * Payload:
 *   [0] CUSTOM_MSG_SWEEP_DONE (0xF3)
 *   [1] 채널 수
 *   [2] dwell time (ms)
 *   [3] TX power (dBm)
 *****************************************************************************/
static void send_sweep_done_msg(EmberNodeId target)
{
  uint8_t msg[4];
  msg[0] = CUSTOM_MSG_SWEEP_DONE;
  msg[1] = (uint8_t)SWEEP_FREQ_COUNT;
  msg[2] = (uint8_t)SWEEP_DWELL_MS;
  msg[3] = (int8_t)(SWEEP_TX_POWER_DECI_DBM / 10);

  EmberStatus st = emberMessageSend(target, CUSTOM_ENDPOINT, 0,
                                     sizeof(msg), msg, tx_options);
  if (st == EMBER_SUCCESS) {
    app_log_info("SWEEP: DONE sent to 0x%04X\n", target);
  } else {
    app_log_error("SWEEP: DONE send FAIL: 0x%02X\n", st);
  }
}

/**************************************************************************//**
 * send_ota_prepare_ack() — OTA 준비 완료 ACK
 *****************************************************************************/
static void send_ota_prepare_ack(EmberNodeId target)
{
  uint8_t msg[1] = { CUSTOM_MSG_PREPARE_ACK };

  EmberStatus st = emberMessageSend(target, CUSTOM_ENDPOINT, 0,
                                     sizeof(msg), msg, tx_options);
  if (st == EMBER_SUCCESS) {
    app_log_info("OTA: ACK sent to 0x%04X\n", target);
  } else {
    app_log_error("OTA: ACK FAIL: 0x%02X\n", st);
  }
}

