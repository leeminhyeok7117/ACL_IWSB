/**************************************************************************//**
 * Incoming message callback
 *
 * 처리 메시지:
 *   1. CUSTOM_MSG_PREPARE_OTA (0xF0) — OTA 준비
 *   2. CUSTOM_MSG_SWEEP_START (0xF2) — 주파수 스윕 시작
 *****************************************************************************/
void emberAfIncomingMessageCallback(EmberIncomingMessage *message)
{
  // ─── 커스텀 엔드포인트 메시지 ───
  if (message->endpoint == CUSTOM_ENDPOINT && message->length >= 1) {

    uint8_t msg_type = message->payload[0];

    // ── OTA 준비 명령 ──
    if (msg_type == CUSTOM_MSG_PREPARE_OTA) {
      if (ota_slave_state != OTA_SLAVE_IDLE) {
        app_log_warning("PREPARE_OTA: Already busy (state=%d)\n",
                        ota_slave_state);
        return;
      }
      if (sweep_state != SWEEP_IDLE) {
        app_log_warning("PREPARE_OTA: Sweep running, rejected.\n");
        return;
      }
      if (message->length < 6) {
        app_log_error("PREPARE_OTA: Payload too short (%d)\n",
                      message->length);
        return;
      }

      uint8_t  tag        = message->payload[1];
      uint32_t image_size = (uint32_t)message->payload[2]
                          | ((uint32_t)message->payload[3] << 8)
                          | ((uint32_t)message->payload[4] << 16)
                          | ((uint32_t)message->payload[5] << 24);

      app_log_info("OTA PREPARE: tag=0x%02X, size=%lu\n", tag, image_size);
      ota_slave_state = OTA_SLAVE_PREPARING;

      int32_t ret = bootloader_eraseStorageSlot(0);
      if (ret != BOOTLOADER_OK) {
        app_log_error("Slot erase FAILED: 0x%lX\n", ret);
        ota_slave_state = OTA_SLAVE_ERROR;
        return;
      }
      app_log_info("Slot 0 erased.\n");
      ota_slave_state = OTA_SLAVE_READY;

      send_ota_prepare_ack(message->source);
      return;
    }

    // ── Frequency Sweep 시작 트리거 ──
    if (msg_type == CUSTOM_MSG_SWEEP_START) {
      // OTA 진행 중이면 거부
      if (ota_slave_state != OTA_SLAVE_IDLE) {
        app_log_warning("SWEEP: OTA busy (state=%d), rejected.\n",
                        ota_slave_state);
        return;
      }
      // 이미 스윕 중이면 무시
      if (sweep_state != SWEEP_IDLE) {
        app_log_warning("SWEEP: Already running (state=%d)\n", sweep_state);
        return;
      }

      sweep_master_id  = message->source;
      sweep_freq_idx   = 0;
      sweep_tick_start = sl_sleeptimer_get_tick_count();
      sweep_state      = SWEEP_WAIT_START;

      app_log_info("SWEEP_START from 0x%04X. RF sweep in %d ms...\n",
                   sweep_master_id, SWEEP_START_DELAY_MS);

      // RAIL 핸들 획득
      rail_handle = sl_rail_util_get_handle(SL_RAIL_UTIL_HANDLE_INST);
      if (rail_handle == NULL) {
        app_log_error("SWEEP: RAIL handle is NULL!\n");
        sweep_state = SWEEP_IDLE;
        return;
      }

      // TX 파워 설정 (전체 스윕에 동일 적용)
      RAIL_Status_t ret = RAIL_SetTxPowerDbm(rail_handle,
                                              SWEEP_TX_POWER_DECI_DBM);
      if (ret != RAIL_STATUS_NO_ERROR) {
        app_log_warning("SWEEP: SetTxPowerDbm(%d) returned 0x%02X\n",
                        SWEEP_TX_POWER_DECI_DBM, ret);
      }
      return;
    }
  }

  // ─── 일반 센서 데이터 메시지 (수신 시 처리할 게 있으면 여기) ───
  if ((message->endpoint != SL_SENSOR_SINK_ENDPOINT)
      || ((tx_options & EMBER_OPTIONS_SECURITY_ENABLED)
          && !(message->options & EMBER_OPTIONS_SECURITY_ENABLED))) {
    return;
  }
}

