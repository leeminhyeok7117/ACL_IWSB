/**************************************************************************//**
 * Stack status callback — 네트워크 상태 변화 감지 + 자동 재접속
 *****************************************************************************/
void emberAfStackStatusCallback(EmberStatus status)
{
  switch (status) {
    case EMBER_NETWORK_UP:
      app_log_info("Network UP (joined)\n");
      network_joined = true;
      break;

    case EMBER_NETWORK_DOWN:
      app_log_info("Network DOWN\n");
      network_joined = false;
      // 스윕 중 일시적 NETWORK_DOWN은 무시 (스윕 완료 후 자동 복구)
      if (sweep_state != SWEEP_IDLE) {
        app_log_info("  (during sweep — will recover after sweep)\n");
      } else {
        // 스윕 중이 아니면 재접속 시도 예약
        join_retry_tick = sl_sleeptimer_get_tick_count();
      }
      break;

    default:
      app_log_info("Stack status: 0x%02X\n", status);
      break;
  }
}

/**************************************************************************//**
 * Tick callback — 메인 루프
 *
 * 처리:
 *   1. LED 상태 표시
 *   2. Sweep TX 상태머신
 *   3. Join 재시도 (네트워크 미연결 시)
 *****************************************************************************/
void emberAfTickCallback(void)
{
  // LED: 스윕 중 빠른 점멸 / 네트워크 UP = ON / DOWN = OFF
  if (sweep_state != SWEEP_IDLE) {
    sl_led_toggle(&sl_led_led0);
  } else if (emberStackIsUp()) {
    sl_led_turn_on(&sl_led_led0);
  } else {
    sl_led_turn_off(&sl_led_led0);
  }

  // Sweep TX 상태머신
  sweep_tx_tick();

  // 네트워크 재접속 (스윕 중이 아닐 때만)
  if (!network_joined && sweep_state == SWEEP_IDLE) {
    uint32_t elapsed = sl_sleeptimer_tick_to_ms(
      sl_sleeptimer_get_tick_count() - join_retry_tick);
    if (elapsed >= JOIN_RETRY_INTERVAL_MS) {
      app_log_info("Retrying network join...\n");
      network_join();
      join_retry_tick = sl_sleeptimer_get_tick_count();
    }
  }
}

