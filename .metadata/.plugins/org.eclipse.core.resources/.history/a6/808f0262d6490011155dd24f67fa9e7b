// -----------------------------------------------------------------------------
//                           Sweep 주파수 테이블
// -----------------------------------------------------------------------------
// EFR32FG12 Sub-GHz: 169~960 MHz
// 아래 테이블은 200~900 MHz, 50 MHz 간격, 15채널.
// → 전체 스윕 시간 = 15 × 50ms = 750ms
//
// 주파수를 변경하려면 이 테이블만 수정.
// 단, SWEEP_FREQ_COUNT (app_process.h)도 함께 변경할 것.
// Master RX 코드에도 동일 테이블 필요.
static const uint32_t sweep_freq_hz[SWEEP_FREQ_COUNT] = {
  200000000UL,   // [0]  200 MHz
  250000000UL,   // [1]  250 MHz
  300000000UL,   // [2]  300 MHz
  350000000UL,   // [3]  350 MHz
  400000000UL,   // [4]  400 MHz
  450000000UL,   // [5]  450 MHz
  500000000UL,   // [6]  500 MHz
  550000000UL,   // [7]  550 MHz
  600000000UL,   // [8]  600 MHz
  650000000UL,   // [9]  650 MHz
  700000000UL,   // [10] 700 MHz
  750000000UL,   // [11] 750 MHz
  800000000UL,   // [12] 800 MHz
  850000000UL,   // [13] 850 MHz
  900000000UL,   // [14] 900 MHz
};

