/**************************************************************************//**
 * send_sweep_start_msg — app_cli.c에서 호출
 *****************************************************************************/
void send_sweep_start_msg(EmberNodeId target)
{
  uint8_t msg[2];
  msg[0] = 0xE0;
  msg[1] = 0x01;

  EmberStatus status = emberMessageSend(target,
                                        CUSTOM_ENDPOINT,
                                        0,
                                        sizeof(msg),
                                        msg,
                                        tx_options);
  app_log_info("Sweep start msg to 0x%04X: status=0x%02X\n", target, status);
}

