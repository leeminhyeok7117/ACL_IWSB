/**************************************************************************//**
 * [신규] register_slave — slave_table에 device_id ↔ node_id 등록/갱신
 *
 * 이미 같은 device_id가 있으면 node_id만 갱신 (재부팅 후 node_id 변경 대응)
 * 새 device_id면 빈 슬롯에 추가
 *****************************************************************************/
static void register_slave(uint8_t device_id, EmberNodeId node_id)
{
  if (device_id < 1 || device_id > MAX_SLAVES) {
    app_log_error("register_slave: invalid device_id=%d (valid: 1~%d)\n",
                  device_id, MAX_SLAVES);
    return;
  }

  // 이미 등록된 device_id → node_id 갱신
  for (uint8_t i = 0; i < MAX_SLAVES; i++) {
    if (slave_table[i].registered && slave_table[i].device_id == device_id) {
      if (slave_table[i].node_id != node_id) {
        app_log_info("Slave device_id=%d: node_id updated 0x%04X → 0x%04X\n",
                     device_id, slave_table[i].node_id, node_id);
        slave_table[i].node_id = node_id;
      } else {
        app_log_info("Slave device_id=%d (node=0x%04X) confirmed online.\n",
                     device_id, node_id);
      }
      return;
    }
  }

  // 새 device_id → 빈 슬롯에 추가
  for (uint8_t i = 0; i < MAX_SLAVES; i++) {
    if (!slave_table[i].registered) {
      slave_table[i].device_id  = device_id;
      slave_table[i].node_id    = node_id;
      slave_table[i].registered = true;
      app_log_info("Slave registered: device_id=%d, node_id=0x%04X (slot %d)\n",
                   device_id, node_id, i);
      return;
    }
  }

  app_log_error("register_slave: table full! (MAX_SLAVES=%d)\n", MAX_SLAVES);
}

/**************************************************************************//**
 * [신규] get_node_id_by_device_id — device_id로 node_id 조회
 *
 * 미등록이면 EMBER_NULL_NODE_ID(0xFFFF) 반환
 *****************************************************************************/
static EmberNodeId get_node_id_by_device_id(uint8_t device_id)
{
  for (uint8_t i = 0; i < MAX_SLAVES; i++) {
    if (slave_table[i].registered && slave_table[i].device_id == device_id) {
      return slave_table[i].node_id;
    }
  }
  return EMBER_NULL_NODE_ID;
}

/**************************************************************************//**
 * AP_OBC I2C 명령 파싱 및 디스패치
 *****************************************************************************/
static void process_obc_command(void)
{
  if (obc_rx_len < 3) {
    app_log_error("OBC: Packet too short (%d bytes)\n", obc_rx_len);
    return;
  }

  uint8_t  cmd         = obc_rx_buffer[0];
  uint16_t payload_len = (uint16_t)obc_rx_buffer[1]
                       | ((uint16_t)obc_rx_buffer[2] << 8);
  const uint8_t *payload = (const uint8_t *)&obc_rx_buffer[3];

  if (3 + payload_len > obc_rx_len) {
    app_log_error("OBC: Payload truncated (expected %d, got %d)\n",
                  payload_len, obc_rx_len - 3);
    return;
  }

  app_log_info("OBC CMD: 0x%02X, payload_len=%d\n", cmd, payload_len);

  switch (cmd) {
    case OBC_CMD_PREPARE:     handle_cmd_prepare(payload, payload_len);     break;
    case OBC_CMD_WRITE_CHUNK: handle_cmd_write_chunk(payload, payload_len); break;
    case OBC_CMD_START_OTA:   handle_cmd_start_ota();                       break;
    case OBC_CMD_STATUS:
      app_log_info("OBC STATUS: ota_state=%d, offset=%lu/%lu, target_dev=%d\n",
                   ota_state, gbl_write_offset, gbl_image_size,
                   ota_target_device_id);
      break;
    default:
      app_log_error("OBC: Unknown CMD 0x%02X\n", cmd);
      break;
  }
}

/**************************************************************************//**
 * CMD 0x01: OTA 준비
 *
 * [변경] payload의 target_node(2B) 필드는 이제 device_id(1B)로 사용.
 *        나머지 1B는 reserved (0x00).
 *
 * 프로토콜:
 *   payload[0]    = device_id (1~4)  ← 변경
 *   payload[1]    = reserved (0x00)  ← 변경 (기존: target_node 상위 바이트)
 *   payload[2..5] = gbl_image_size (LE)
 *   payload[6]    = image_tag
 *****************************************************************************/
static void handle_cmd_prepare(const uint8_t *payload, uint16_t len)
{
  if (len < 7) {
    app_log_error("OBC PREPARE: payload too short\n");
    return;
  }

  // ─── [변경] payload[0]을 device_id로 해석 ────────────────────────────────
  //   0x00      → TX 자체 업데이트
  //   0x01~0x04 → RX OTA 분배
  uint8_t dev_id = payload[0];

  if (dev_id == OBC_TARGET_TX_SELF) {
    // ───────────── TX 자체 업데이트 준비 ─────────────
    ota_is_self_update   = true;
    ota_target_device_id = DEVICE_ID_NONE;
    ota_target_node      = EMBER_NULL_NODE_ID;
    gbl_image_size       = (uint32_t)payload[2]
                         | ((uint32_t)payload[3] << 8)
                         | ((uint32_t)payload[4] << 16)
                         | ((uint32_t)payload[5] << 24);
    ota_image_tag        = payload[6];
    app_log_info("OTA PREPARE: TX SELF-UPDATE, size=%lu, tag=0x%02X\n",
                 gbl_image_size, ota_image_tag);
  } else {
    // ───────────── RX OTA 분배 준비 (기존) ─────────────
    if (dev_id < 1 || dev_id > MAX_SLAVES) {
      app_log_error("OBC PREPARE: invalid device_id=%d\n", dev_id);
      return;
    }

    EmberNodeId resolved_node = get_node_id_by_device_id(dev_id);
    if (resolved_node == EMBER_NULL_NODE_ID) {
      app_log_error("OBC PREPARE: device_id=%d not registered in slave table\n",
                    dev_id);
      return;
    }

    ota_is_self_update   = false;
    ota_target_device_id = dev_id;
    ota_target_node      = resolved_node;
    gbl_image_size       = (uint32_t)payload[2]
                         | ((uint32_t)payload[3] << 8)
                         | ((uint32_t)payload[4] << 16)
                         | ((uint32_t)payload[5] << 24);
    ota_image_tag        = payload[6];

    app_log_info("OTA PREPARE: device_id=%d → node=0x%04X, size=%lu, tag=0x%02X\n",
                 dev_id, ota_target_node, gbl_image_size, ota_image_tag);
  }

  app_log_info("Erasing storage slot 0...\n");
  int32_t ret = bootloader_eraseStorageSlot(0);
  if (ret != BOOTLOADER_OK) {
    app_log_error("Slot erase FAILED: 0x%lX\n", ret);
    ota_state = OTA_ERROR;
    return;
  }
  app_log_info("Slot 0 erased.\n");

  gbl_write_offset = 0;
  ota_state = OTA_RECEIVING_FW;
}

/**************************************************************************//**
 * CMD 0x02: GBL 펌웨어 청크 쓰기
 *****************************************************************************/
static void handle_cmd_write_chunk(const uint8_t *payload, uint16_t len)
{
  if (ota_state != OTA_RECEIVING_FW) {
    app_log_error("OBC WRITE_CHUNK: Not in RECEIVING state\n");
    return;
  }

  if (len == 0) return;

  int32_t ret = bootloader_writeStorage(0, gbl_write_offset,
                                         (uint8_t *)payload, len);
  if (ret != BOOTLOADER_OK) {
    app_log_error("writeStorage FAIL at offset %lu: 0x%lX\n",
                  gbl_write_offset, ret);
    ota_state = OTA_ERROR;
    return;
  }

  gbl_write_offset += len;

  if (gbl_image_size > 0) {
    uint32_t pct = (gbl_write_offset * 100) / gbl_image_size;
    static uint32_t last_pct = 0;
    if (pct / 10 > last_pct / 10) {
      app_log_info("FW upload: %lu%% (%lu/%lu)\n",
                   pct, gbl_write_offset, gbl_image_size);
    }
    last_pct = pct;
  }

  if (gbl_write_offset >= gbl_image_size) {
    app_log_info("FW upload complete. %lu bytes written.\n", gbl_write_offset);
    ota_state = OTA_FW_READY;
  }
}

/**************************************************************************//**
 * CMD 0x03: OTA 배포 시작
 *****************************************************************************/
static void handle_cmd_start_ota(void)
{
  if (ota_state != OTA_FW_READY) {
    app_log_error("OBC START_OTA: FW not ready (state=%d)\n", ota_state);
    return;
  }

  if (ota_is_self_update) {
    // ───────────── TX 자체 설치 (RF 미사용) ─────────────
    // Gecko Bootloader 로컬 설치 시퀀스:
    //   verifyImage → setImageToBootload(0) → rebootAndInstall()
    app_log_info("I2C CMD 0x03: TX SELF-UPDATE install...\n");

    int32_t ret = bootloader_verifyImage(0, NULL);
    if (ret != BOOTLOADER_OK) {
      app_log_error("Self-update: verifyImage FAIL 0x%lX\n", ret);
      ota_state = OTA_ERROR;
      return;
    }
    ret = bootloader_setImageToBootload(0);
    if (ret != BOOTLOADER_OK) {
      app_log_error("Self-update: setImageToBootload FAIL 0x%lX\n", ret);
      ota_state = OTA_ERROR;
      return;
    }
    app_log_info("Self-update verified. Rebooting to install...\n");
    ota_state = OTA_REQUEST_BOOTLOAD;
    bootloader_rebootAndInstall();   // 복귀 안 함. 재부팅 후 emberNetworkInit 으로 복원.
    return;
  }

  // ───────────── RX OTA 분배 (기존) ─────────────
  // 우주 모드에서는 CMD 0x01 PREPARE 시 device_id가 이미 설정됨
  if (ota_target_device_id == DEVICE_ID_NONE
      || ota_target_node == EMBER_NULL_NODE_ID) {
    app_log_error("OBC START_OTA: target not set (run CMD 0x01 first)\n");
    return;
  }
  app_log_info("I2C CMD 0x03: Starting OTA...\n");
  start_ota_distribution();
}

/**************************************************************************//**
 * Slave에 OTA 준비 커스텀 메시지 전송
 *****************************************************************************/
static void send_slave_prepare_msg(EmberNodeId target)
{
  uint8_t msg[6];
  msg[0] = MSG_TYPE_OTA_PREPARE;
  msg[1] = ota_image_tag;
  msg[2] = (uint8_t)(gbl_image_size & 0xFF);
  msg[3] = (uint8_t)((gbl_image_size >> 8) & 0xFF);
  msg[4] = (uint8_t)((gbl_image_size >> 16) & 0xFF);
  msg[5] = (uint8_t)((gbl_image_size >> 24) & 0xFF);

  EmberStatus status = emberMessageSend(target,
                                        CUSTOM_ENDPOINT,
                                        0,
                                        sizeof(msg),
                                        msg,
                                        tx_options);
  if (status != EMBER_SUCCESS) {
    app_log_error("Failed to send prepare msg to 0x%04X: 0x%02X\n",
                  target, status);
  }
}

/**************************************************************************//**
 * OTA 자동화 상태머신
 *****************************************************************************/
static void ota_state_machine_tick(void)
{
  switch (ota_state) {

    case OTA_WAITING_SLAVE_PREPARE: {
      if (slave_prepare_acked) {
        app_log_info("Slave ready. Starting OTA distribution...\n");

        EmberAfOtaUnicastBootloaderStatus ota_ret =
          emberAfPluginOtaUnicastBootloaderServerInitiateImageDistribution(
            ota_target_node,
            gbl_image_size,
            ota_image_tag);

        if (ota_ret == EMBER_OTA_UNICAST_BOOTLOADER_STATUS_SUCCESS) {
          app_log_info("OTA distribution initiated.\n");
          ota_state = OTA_DISTRIBUTING;
        } else {
          app_log_error("OTA initiate FAILED: 0x%02X\n", ota_ret);
          ota_state = OTA_ERROR;
        }
      } else if (sl_sleeptimer_tick_to_ms(
                     sl_sleeptimer_get_tick_count() - ota_timer_start)
                 > OTA_SLAVE_PREPARE_TIMEOUT_MS) {
        app_log_error("Slave prepare TIMEOUT. Retrying...\n");
        send_slave_prepare_msg(ota_target_node);
        ota_timer_start = sl_sleeptimer_get_tick_count();
      }
      break;
    }

    case OTA_DISTRIBUTING:
      break;

    case OTA_REQUEST_BOOTLOAD: {
      if (!bootload_req_pending) break;
      bootload_req_pending = false;

      app_log_info("OTA: Requesting bootload...\n");
      EmberAfOtaUnicastBootloaderStatus bl_ret =
        emberAfPluginUnicastBootloaderServerInitiateRequestTargetBootload(
          OTA_BOOTLOAD_DELAY_MS,
          ota_image_tag,
          ota_target_node);

      if (bl_ret == EMBER_OTA_UNICAST_BOOTLOADER_STATUS_SUCCESS) {
        app_log_info("Bootload request sent (delay=%dms)\n", OTA_BOOTLOAD_DELAY_MS);
        ota_state = OTA_WAITING_BOOTLOAD;
      } else {
        app_log_error("Bootload request FAILED: 0x%02X\n", bl_ret);
        ota_state = OTA_ERROR;
      }
      break;
    }

    case OTA_WAITING_BOOTLOAD:
      break;

    case OTA_VERIFYING:
      break;

    case OTA_COMPLETE:
      ota_state = OTA_IDLE;
      break;

    case OTA_ERROR:
      app_log_error("=== OTA ERROR. Reset state to IDLE. ===\n");
      ota_target_device_id = DEVICE_ID_NONE;  // [신규] 에러 시 타겟 초기화
      ota_is_self_update   = false;           // [신규] 자체 업데이트 플래그 초기화
      ota_state = OTA_IDLE;
      break;

    case OTA_IDLE:
    case OTA_RECEIVING_FW:
    case OTA_FW_READY:
    case OTA_FW_READY_MANUAL:
    default:
      break;
  }
}

/**************************************************************************//**
 * 우주/지상 모드 공통 OTA 시작
 *****************************************************************************/
static void start_ota_distribution(void)
{
  app_log_info("OTA distribution start → Slave 0x%04X (device_id=%d), tag=0x%02X, size=%lu\n",
               ota_target_node, ota_target_device_id, ota_image_tag, gbl_image_size);
  slave_prepare_acked = false;
  send_slave_prepare_msg(ota_target_node);
  ota_timer_start = sl_sleeptimer_get_tick_count();
  ota_state = OTA_WAITING_SLAVE_PREPARE;
}

/**************************************************************************//**
 * bootload_req_timer 콜백
 *****************************************************************************/
static void bootload_req_timer_cb(sl_sleeptimer_timer_handle_t *handle, void *data)
{
  (void)handle;
  (void)data;
  bootload_req_pending = true;
}

// ─────────────────────────────────────────────────────────────────────────────
//  [신규] TX 코디네이터 폴링 — 충돌 원천 차단
//  TX → 등록된 RX 를 slave_table 순서대로 폴링
//  RX 는 POLL_REQUEST 수신 시에만 POLL_RESPONSE 전송 → 동시 전송 불가
// ─────────────────────────────────────────────────────────────────────────────

/**************************************************************************//**
 * poll_next_slave — 다음 등록된 슬레이브에게 POLL_REQUEST 전송
 *****************************************************************************/
static void poll_next_slave(void)
{
  // 등록된 슬레이브 중 poll_idx 부터 순서대로 검색
  uint8_t found = MAX_SLAVES;   // sentinel
  for (uint8_t i = 0; i < MAX_SLAVES; i++) {
    uint8_t idx = (poll_idx + i) % MAX_SLAVES;
    if (slave_table[idx].registered) {
      found    = idx;
      poll_idx = (idx + 1) % MAX_SLAVES;   // 다음 호출 때 다음 노드로
      break;
    }
  }

  if (found == MAX_SLAVES) {
    // 등록된 슬레이브 없음 → POLL_CYCLE_INTERVAL 후 재시도
    poll_running    = false;
    poll_cycle_done = true;
    sl_sleeptimer_start_timer_ms(&poll_cycle_timer, POLL_CYCLE_INTERVAL_MS,
                                 poll_cycle_timer_cb, NULL, 0, 0);
    return;
  }

  // 이번 사이클 시작 시 online 초기화 (응답이 와야만 true)
  slave_table[found].online = false;

  uint8_t msg[2] = { MSG_TYPE_POLL_REQUEST, slave_table[found].device_id };
  EmberStatus st = emberMessageSend(slave_table[found].node_id,
                                    CUSTOM_ENDPOINT, 0,
                                    sizeof(msg), msg, tx_options);
  if (st == EMBER_SUCCESS) {
    app_log_info("[POLL] → device_id=%d (node=0x%04X)\n",
                 slave_table[found].device_id, slave_table[found].node_id);
    poll_waiting = true;
    poll_anchor  = sl_sleeptimer_get_tick_count();
  } else {
    app_log_error("[POLL] Send fail to device_id=%d: 0x%02X\n",
                  slave_table[found].device_id, st);
    poll_waiting = false;   // 타임아웃 없이 즉시 다음 노드
  }
}

/**************************************************************************//**
 * poll_tick — emberAfTickCallback 에서 매 tick 호출
 *   poll_waiting==true 이면 POLL_RESPONSE_TIMEOUT_MS 대기.
 *   응답이 오거나 타임아웃되면 다음 노드로 진행.
 *   poll_idx 가 0으로 돌아오면 1 사이클 완료 → POLL_CYCLE_INTERVAL 후 재시작.
 *****************************************************************************/
static void poll_tick(void)
{
  if (poll_cycle_done) return;   // 사이클 간 대기 중

  if (poll_waiting) {
    uint32_t elapsed = sl_sleeptimer_tick_to_ms(
                         sl_sleeptimer_get_tick_count() - poll_anchor);
    if (elapsed < POLL_RESPONSE_TIMEOUT_MS) {
      return;   // 아직 대기 중
    }
    // 타임아웃 → offline 처리 후 다음 노드
    app_log_info("[POLL] Timeout waiting for response.\n");
    poll_waiting = false;
  }

  // poll_idx 가 0이면 사이클 완료 → 대기
  if (poll_idx == 0) {
    app_log_info("[POLL] Cycle complete. Next in %lums.\n", POLL_CYCLE_INTERVAL_MS);
    poll_running    = false;
    poll_cycle_done = true;
    sl_sleeptimer_start_timer_ms(&poll_cycle_timer, POLL_CYCLE_INTERVAL_MS,
                                 poll_cycle_timer_cb, NULL, 0, 0);
    return;
  }

  poll_next_slave();
}

/**************************************************************************//**
 * poll_cycle_timer_cb — 사이클 간 대기 완료 → 다음 사이클 시작
 *****************************************************************************/
static void poll_cycle_timer_cb(sl_sleeptimer_timer_handle_t *handle, void *data)
{
  (void)handle; (void)data;
  poll_idx        = 0;
  poll_running    = true;
  poll_cycle_done = false;
  poll_waiting    = false;
  poll_next_slave();
}

/**************************************************************************//**
 * polling_restart — CLI 또는 외부에서 폴링 사이클 강제 재시작
 *****************************************************************************/
void polling_restart(void)
{
  sl_sleeptimer_stop_timer(&poll_cycle_timer);
  poll_idx        = 0;
  poll_running    = true;
  poll_cycle_done = false;
  poll_waiting    = false;
  app_log_info("[POLL] Polling restarted.\n");
  poll_next_slave();
}

/**************************************************************************//**
 * TX 자동 리셋 콜백
 *****************************************************************************/
static void tx_reset_cb(sl_sleeptimer_timer_handle_t *handle, void *data)
{
  (void)handle;
  (void)data;
  app_log_info("TX auto-reset after OTA...\n");
  NVIC_SystemReset();
}

