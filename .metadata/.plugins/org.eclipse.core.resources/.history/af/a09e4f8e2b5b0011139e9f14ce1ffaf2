/// AP_OBC → Master I2C 명령 코드
#define OBC_CMD_PREPARE       0x01
#define OBC_CMD_WRITE_CHUNK   0x02
#define OBC_CMD_START_OTA     0x03
#define OBC_CMD_STATUS        0x04

/// [신규] PREPARE payload[0](device_id) 약속값
///   0x00       → TX 자체 펌웨어 업데이트 (RF 미사용, 로컬 부트로더 설치)
///   0x01~0x04  → RX device_id 로 OTA 분배 (기존 방식)
/// ※ AP_OBC 는 TX 자체 업데이트 시 device_id 자리에 0x00 을 보내면 됨.
#define OBC_TARGET_TX_SELF    0x00

/// Master → Slave 커스텀 엔드포인트
#define CUSTOM_ENDPOINT          0x02

/// OTA 자동화 타이밍
#define OTA_SLAVE_PREPARE_TIMEOUT_MS   10000
#define OTA_BOOTLOAD_DELAY_MS          2000
#define OTA_VERIFY_TIMEOUT_MS          30000  // 30초

/// [신규] device_id 미설정 sentinel 값
#define DEVICE_ID_NONE  0xFFU

/// [신규] TX 코디네이터 폴링 타이밍
// 각 노드 응답 대기 최대 시간. 이 안에 POLL_RESPONSE 없으면 offline 처리 후 다음 노드로.
#define POLL_RESPONSE_TIMEOUT_MS  1500U
// 전체 폴링 사이클 완료 후 다음 사이클까지 대기 시간
#define POLL_CYCLE_INTERVAL_MS    5000U

