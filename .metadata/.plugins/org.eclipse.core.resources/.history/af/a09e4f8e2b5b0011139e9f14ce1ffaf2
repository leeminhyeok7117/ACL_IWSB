/**************************************************************************//**
 * BTN0 트리거 — OTA 시작
 *
 * [변경] ota_target_device_id가 CLI로 설정되어 있고,
 *        해당 device_id가 slave_table에 등록된 경우에만 OTA 시작.
 *        지상 모드(OTA_FW_READY_MANUAL)와 우주 모드(OTA_FW_READY) 모두 동일하게 동작.
 *****************************************************************************/
void sl_button_on_change(const sl_button_t *handle)
{
  if (handle != &sl_button_btn0
      || sl_button_get_state(handle) != SL_SIMPLE_BUTTON_PRESSED) {
    return;
  }

  // ─── OTA 준비 상태 확인 ───────────────────────────────────────────────────
  if (ota_state != OTA_FW_READY_MANUAL && ota_state != OTA_FW_READY) {
    app_log_info("BTN0: No GBL loaded or OTA in progress (state=%d)\n", ota_state);
    return;
  }

  // ─── CLI로 타겟이 선택되었는지 확인 ──────────────────────────────────────
  if (ota_target_device_id == DEVICE_ID_NONE) {
    app_log_info("BTN0: OTA target not selected!\n");
    app_log_info("  Use CLI: ota_target <1-%d>\n", MAX_SLAVES);
    app_log_info("  Use CLI: slave_list  (등록된 슬레이브 확인)\n");
    return;
  }

  // ─── slave_table에서 node_id 조회 ────────────────────────────────────────
  EmberNodeId target_node = get_node_id_by_device_id(ota_target_device_id);
  if (target_node == EMBER_NULL_NODE_ID) {
    app_log_info("BTN0: device_id=%d is not registered in slave table!\n",
                 ota_target_device_id);
    app_log_info("  Check slave list: CLI 'slave_list'\n");
    return;
  }

  // ─── OTA 시작 ─────────────────────────────────────────────────────────────
  ota_target_node = target_node;
  app_log_info("BTN0: OTA start → device_id=%d, node=0x%04X\n",
               ota_target_device_id, ota_target_node);
  start_ota_distribution();
}

/**************************************************************************//**
 * Incoming message callback
 *
 * [기존] Slave OTA 준비 ACK, 센서 데이터, RF 버전 리포트 처리
 * [신규] MSG_TYPE_ID_ANNOUNCE(0xA0) 처리
 *        RX가 Join 완료 후 자신의 device_id를 TX에 알리는 메시지
 *****************************************************************************/
void emberAfIncomingMessageCallback(EmberIncomingMessage *message)
{
  if (message->endpoint != CUSTOM_ENDPOINT
      && message->endpoint != SL_SENSOR_SINK_ENDPOINT) {
    return;
  }

  if (message->length < 1) return;

  uint8_t msg_type = message->payload[0];

  // ─── [신규] RX device_id 알림 메시지 ────────────────────────────────────
  if (msg_type == MSG_TYPE_ID_ANNOUNCE) {
    if (message->length < 2) {
      app_log_error("ID_ANNOUNCE: payload too short from 0x%04X\n",
                    message->source);
      return;
    }
    uint8_t dev_id = message->payload[1];
    register_slave(dev_id, message->source);
    return;
  }

  // ─── [신규] RX 폴링 응답 ─────────────────────────────────────────────────
  if (msg_type == MSG_TYPE_POLL_RESPONSE) {
    if (message->length < 3) return;
    uint8_t dev_id  = message->payload[1];
    uint8_t fw_ver  = message->payload[2];
    // slave_table online 상태 갱신
    for (uint8_t i = 0; i < MAX_SLAVES; i++) {
      if (slave_table[i].registered && slave_table[i].device_id == dev_id) {
        slave_table[i].online     = true;
        slave_table[i].fw_version = fw_ver;
        break;
      }
    }
    app_log_info("[POLL] RX device_id=%d (node=0x%04X) online. fw=0x%02X\n",
                 dev_id, message->source, fw_ver);
    // 대기 중이던 노드에서 응답이 왔으면 다음 노드로 진행
    if (poll_waiting) {
      poll_waiting = false;
    }
    return;
  }

  // ─── RX 펌웨어 버전 리포트 ──────────────────────────────────────────────
  if (msg_type == MSG_TYPE_FW_VERSION_REPORT && message->length >= 2) {
    ota_rx_fw_version = message->payload[1];
    if (ota_state == OTA_VERIFYING && message->source == ota_target_node) {
      app_log_info(">>> [OTA VERIFY] RX Node 0x%04X booted. FW version: 0x%02X\n",
                   message->source, ota_rx_fw_version);
      ota_rf_verified = true;
      app_log_info(">>> [OTA VERIFY] RF version report CONFIRMED. OTA SUCCESS.\n");
    } else {
      app_log_info("RX Node 0x%04X online. FW version: 0x%02X\n",
                   message->source, ota_rx_fw_version);
    }
    return;
  }

  // ─── Slave OTA 준비 ACK ───────────────────────────────────────────────────
  if (msg_type == MSG_TYPE_OTA_PREPARE_ACK) {
    app_log_info("Slave 0x%04X OTA prepare ACK received.\n", message->source);
    slave_prepare_acked = true;
    return;
  }

  // ─── 일반 센서 데이터 ─────────────────────────────────────────────────────
  if (message->endpoint != SL_SENSOR_SINK_ENDPOINT) return;
  if ((tx_options & EMBER_OPTIONS_SECURITY_ENABLED)
      && !(message->options & EMBER_OPTIONS_SECURITY_ENABLED)) {
    return;
  }

  app_log_info("RX: Data from 0x%04X:", message->source);
  for (int j = 0; j < message->length; j++) {
    app_log_info(" %02X", message->payload[j]);
  }

  int32_t  temperature             = 0;
  uint32_t humidity                = 0;
  bool     temperature_is_negative = false;
  int32_t  temperature_decimal     = 0;
  uint32_t humidity_decimal        = 0;

  temperature = (int32_t)emberFetchLowHighInt32u(message->payload);
  humidity    = emberFetchLowHighInt32u(message->payload + 4);

  if (temperature < 0) temperature_is_negative = true;
  temperature_decimal = abs(temperature) - (abs(temperature) / 1000) * 1000;
  temperature = abs(temperature / 1000);
  humidity_decimal = humidity - (humidity / 1000) * 1000;
  humidity = humidity / 1000;

  app_log_info(" Temp: %s%d.%03dC Hum: %d.%03d%%\n",
               (temperature_is_negative ? "-" : "+"),
               temperature, temperature_decimal,
               humidity, humidity_decimal);
}

