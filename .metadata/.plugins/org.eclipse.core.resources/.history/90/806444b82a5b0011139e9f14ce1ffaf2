/***************************************************************************//**
 * @file
 * @brief app_process.h — Slave (Sensor / OTA Client)
 *
 * [재작성 핵심]
 *   - DEVICE_ID_NVM3_KEY 를 여기로 중앙화(app_init.c / app_cli.c 공용)
 *   - MY_DEVICE_ID 는 "NVM3 미설정 시 폴백 기본값"으로 의미 변경
 *     → 부팅 시 app_init.c 가 NVM3에서 device_id 를 읽어 우선 적용
 ******************************************************************************/
#ifndef APP_PROCESS_H
#define APP_PROCESS_H

// ─────────────────────────────────────────────────────────────────────────────
//  RF 메시지 타입 (TX app_process.h와 반드시 동일한 값)
// ─────────────────────────────────────────────────────────────────────────────
#define MSG_TYPE_OTA_PREPARE        0xF0U
#define MSG_TYPE_OTA_PREPARE_ACK    0xF1U
#define MSG_TYPE_FW_VERSION_REPORT  0xF2U
#define MSG_TYPE_ID_ANNOUNCE        0xA0U

// ─────────────────────────────────────────────────────────────────────────────
//  현재 펌웨어 버전 — OTA 업데이트 시 변경 후 빌드
// ─────────────────────────────────────────────────────────────────────────────
#define FW_VERSION_MAJOR    0x01U

// ─────────────────────────────────────────────────────────────────────────────
//  NVM3 key — device_id 영구 저장용 (USER 도메인, 스택 토큰과 충돌 없음)
//  app_init.c(읽기) 와 app_cli.c(쓰기) 가 반드시 동일 키를 사용해야 함
// ─────────────────────────────────────────────────────────────────────────────
#define DEVICE_ID_NVM3_KEY   0x00001U

// ─────────────────────────────────────────────────────────────────────────────
//  Device ID 폴백 기본값
//  ┌────────────────────────────────────────────────────────────────┐
//  │  정상 운용 절차:                                                │
//  │    1) 보드 플래싱 후 CLI: set_id <1~4>  →  NVM3에 영구 저장     │
//  │    2) CLI: reset        →  재부팅                               │
//  │    3) 이후 부팅 시 app_init.c 가 NVM3 값을 자동 로드            │
//  │  NVM3에 값이 없을 때만 아래 MY_DEVICE_ID 가 사용됨             │
//  └────────────────────────────────────────────────────────────────┘
#define MY_DEVICE_ID   1U

#endif // APP_PROCESS_H
