/**************************************************************************//**
 * Tick callback — 메인 루프 (AP_OBC 명령 처리 + OTA 상태머신)
 *****************************************************************************/
void emberAfTickCallback(void)
{
  // LED: 네트워크 상태 표시
  if (emberStackIsUp()) {
    sl_led_turn_on(&sl_led_led0);
  } else {
    sl_led_turn_off(&sl_led_led0);
  }

  // ─── AP_OBC 명령 처리 ───
  if (obc_cmd_ready) {
    obc_cmd_ready = false;
    process_obc_command();
  }

  // ─── OTA 자동화 상태머신 ───
  ota_state_machine_tick();
}

/**************************************************************************//**
 * [OTA Server Callback] 이미지 세그먼트 읽기
 * - 배포 과정에서 플러그인이 호출
 * - Bootloader storage slot 0에서 직접 읽어서 반환
 *****************************************************************************/
bool emberAfPluginOtaUnicastBootloaderServerGetImageSegmentCallback(
  uint32_t startIndex,
  uint32_t endIndex,
  uint8_t  imageTag,
  uint8_t *imageSegment)
{
  (void)imageTag;

  uint32_t len = endIndex - startIndex + 1;
  int32_t ret = bootloader_readStorage(0, startIndex, imageSegment, len);

  if (ret != BOOTLOADER_OK) {
    app_log_error("OTA: readStorage failed at offset %lu, err=0x%lX\n",
                  startIndex, ret);
    return false;
  }
  return true;
}

/**************************************************************************//**
 * [OTA Server Callback] 이미지 배포 완료
 *****************************************************************************/
void emberAfPluginOtaUnicastBootloaderServerImageDistributionCompleteCallback(
  EmberAfOtaUnicastBootloaderStatus status)
{
  if (status == EMBER_OTA_UNICAST_BOOTLOADER_STATUS_SUCCESS) {
    app_log_info("OTA: Distribution SUCCESS. Requesting bootload...\n");
    ota_state = OTA_REQUEST_BOOTLOAD;
  } else {
    app_log_error("OTA: Distribution FAILED, status=0x%02X\n", status);
    ota_state = OTA_ERROR;
  }
}

/**************************************************************************//**
 * [OTA Server Callback] 부트로드 요청 완료
 *****************************************************************************/
void emberAfPluginOtaUnicastBootloaderServerRequestTargetBootloadCompleteCallback(
  EmberAfOtaUnicastBootloaderStatus status)
{
  if (status == EMBER_OTA_UNICAST_BOOTLOADER_STATUS_SUCCESS) {
    app_log_info("OTA: Bootload request SUCCESS. Slave will reboot.\n");
    ota_state = OTA_COMPLETE;
  } else {
    app_log_error("OTA: Bootload request FAILED, status=0x%02X\n", status);
    ota_state = OTA_ERROR;
  }
}

