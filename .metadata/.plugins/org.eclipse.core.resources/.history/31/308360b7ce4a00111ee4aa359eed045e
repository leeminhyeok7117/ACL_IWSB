/**************************************************************************//**
 * AP_OBC I2C 명령 파싱 및 디스패치
 *
 * 패킷 구조: [CMD(1B)] [PAYLOAD_LEN(2B, LE)] [PAYLOAD(N)]
 *****************************************************************************/
static void process_obc_command(void)
{
  if (obc_rx_len < 3) {
    app_log_error("OBC: Packet too short (%d bytes)\n", obc_rx_len);
    return;
  }

  uint8_t cmd = obc_rx_buffer[0];
  uint16_t payload_len = (uint16_t)obc_rx_buffer[1]
                       | ((uint16_t)obc_rx_buffer[2] << 8);
  const uint8_t *payload = (const uint8_t *)&obc_rx_buffer[3];

  // 길이 검증
  if (3 + payload_len > obc_rx_len) {
    app_log_error("OBC: Payload truncated (expected %d, got %d)\n",
                  payload_len, obc_rx_len - 3);
    return;
  }

  app_log_info("OBC CMD: 0x%02X, payload_len=%d\n", cmd, payload_len);

  switch (cmd) {
    case OBC_CMD_PREPARE:
      handle_cmd_prepare(payload, payload_len);
      break;
    case OBC_CMD_WRITE_CHUNK:
      handle_cmd_write_chunk(payload, payload_len);
      break;
    case OBC_CMD_START_OTA:
      handle_cmd_start_ota();
      break;
    case OBC_CMD_STATUS:
      // TODO: I2C read 방향으로 상태 반환 구현
      app_log_info("OBC STATUS: ota_state=%d, offset=%lu/%lu\n",
                   ota_state, gbl_write_offset, gbl_image_size);
      break;
    default:
      app_log_error("OBC: Unknown CMD 0x%02X\n", cmd);
      break;
  }
}

/**************************************************************************//**
 * CMD 0x01: OTA 준비
 * Payload: [target_node_id(2B LE)] [image_size(4B LE)] [image_tag(1B)]
 *
 * 동작:
 *   1. Storage slot 0 erase
 *   2. 메타데이터 저장
 *   3. 상태 → OTA_RECEIVING_FW
 *****************************************************************************/
static void handle_cmd_prepare(const uint8_t *payload, uint16_t len)
{
  if (len < 7) {
    app_log_error("OBC PREPARE: payload too short\n");
    return;
  }

  ota_target_node = (EmberNodeId)((uint16_t)payload[0] | ((uint16_t)payload[1] << 8));
  gbl_image_size  = (uint32_t)payload[2]
                  | ((uint32_t)payload[3] << 8)
                  | ((uint32_t)payload[4] << 16)
                  | ((uint32_t)payload[5] << 24);
  ota_image_tag   = payload[6];

  app_log_info("OTA PREPARE: target=0x%04X, size=%lu, tag=0x%02X\n",
               ota_target_node, gbl_image_size, ota_image_tag);

  // Storage slot 0 erase (시간이 걸릴 수 있음 — chunked erase 권장)
  app_log_info("Erasing storage slot 0...\n");
  int32_t ret = bootloader_eraseStorageSlot(0);
  if (ret != BOOTLOADER_OK) {
    app_log_error("Slot erase FAILED: 0x%lX\n", ret);
    ota_state = OTA_ERROR;
    return;
  }
  app_log_info("Slot 0 erased.\n");

  gbl_write_offset = 0;
  ota_state = OTA_RECEIVING_FW;
}

/**************************************************************************//**
 * CMD 0x02: GBL 펌웨어 청크 쓰기
 * Payload: [chunk_data(N bytes)]
 *
 * AP_OBC가 순차적으로 chunk를 보내고 Master가 storage에 기록
 *****************************************************************************/
static void handle_cmd_write_chunk(const uint8_t *payload, uint16_t len)
{
  if (ota_state != OTA_RECEIVING_FW) {
    app_log_error("OBC WRITE_CHUNK: Not in RECEIVING state\n");
    return;
  }

  if (len == 0) return;

  int32_t ret = bootloader_writeStorage(0, gbl_write_offset,
                                         (uint8_t *)payload, len);
  if (ret != BOOTLOADER_OK) {
    app_log_error("writeStorage FAIL at offset %lu: 0x%lX\n",
                  gbl_write_offset, ret);
    ota_state = OTA_ERROR;
    return;
  }

  gbl_write_offset += len;

  // 진행률 표시 (10% 단위)
  if (gbl_image_size > 0) {
    uint32_t pct = (gbl_write_offset * 100) / gbl_image_size;
    static uint32_t last_pct = 0;
    if (pct / 10 > last_pct / 10) {
      app_log_info("FW upload: %lu%% (%lu/%lu)\n",
                   pct, gbl_write_offset, gbl_image_size);
    }
    last_pct = pct;
  }

  // 전체 수신 완료?
  if (gbl_write_offset >= gbl_image_size) {
    app_log_info("FW upload complete. %lu bytes written.\n", gbl_write_offset);
    ota_state = OTA_FW_READY;
  }
}

/**************************************************************************//**
 * CMD 0x03: OTA 배포 시작
 *
 * 동작:
 *   1. Bootloader image validation (선택)
 *   2. Slave에 커스텀 메시지로 준비 명령
 *   3. ACK 대기 → distribution 시작
 *****************************************************************************/
static void handle_cmd_start_ota(void)
{
  if (ota_state != OTA_FW_READY) {
    app_log_error("OBC START_OTA: FW not ready (state=%d)\n", ota_state);
    return;
  }

  // (선택) 이미지 검증
  app_log_info("Validating GBL image in slot 0...\n");
  // bootloader_verifyImage()는 시간이 오래 걸릴 수 있으므로
  // 필요시 chunked verification 사용
  // 여기서는 skip하고 바로 진행 (실제 운용에서는 검증 권장)

  // Slave에 준비 명령 전송
  app_log_info("Sending prepare command to Slave 0x%04X...\n", ota_target_node);
  slave_prepare_acked = false;
  send_slave_prepare_msg(ota_target_node);

  ota_timer_start = sl_sleeptimer_get_tick_count();
  ota_state = OTA_WAITING_SLAVE_PREPARE;
}

/**************************************************************************//**
 * Slave에 OTA 준비 커스텀 메시지 전송
 *
 * Payload: [CUSTOM_MSG_PREPARE_OTA(1B)] [image_tag(1B)] [image_size(4B LE)]
 *****************************************************************************/
static void send_slave_prepare_msg(EmberNodeId target)
{
  uint8_t msg[6];
  msg[0] = CUSTOM_MSG_PREPARE_OTA;
  msg[1] = ota_image_tag;
  msg[2] = (uint8_t)(gbl_image_size & 0xFF);
  msg[3] = (uint8_t)((gbl_image_size >> 8) & 0xFF);
  msg[4] = (uint8_t)((gbl_image_size >> 16) & 0xFF);
  msg[5] = (uint8_t)((gbl_image_size >> 24) & 0xFF);

  EmberStatus status = emberMessageSend(target,
                                         CUSTOM_ENDPOINT,
                                         0, // messageTag
                                         sizeof(msg),
                                         msg,
                                         tx_options);
  if (status != EMBER_SUCCESS) {
    app_log_error("Failed to send prepare msg: 0x%02X\n", status);
  }
}

/**************************************************************************//**
 * OTA 자동화 상태머신 — emberAfTickCallback에서 호출
 *****************************************************************************/
static void ota_state_machine_tick(void)
{
  switch (ota_state) {

    case OTA_WAITING_SLAVE_PREPARE: {
      if (slave_prepare_acked) {
        app_log_info("Slave ready. Starting OTA distribution...\n");

        EmberAfOtaUnicastBootloaderStatus ota_ret =
          emberAfPluginOtaUnicastBootloaderServerInitiateImageDistribution(
            ota_target_node,
            gbl_image_size,
            ota_image_tag);

        if (ota_ret == EMBER_OTA_UNICAST_BOOTLOADER_STATUS_SUCCESS) {
          app_log_info("OTA distribution initiated.\n");
          ota_state = OTA_DISTRIBUTING;
        } else {
          app_log_error("OTA initiate FAILED: 0x%02X\n", ota_ret);
          ota_state = OTA_ERROR;
        }
      } else if (sl_sleeptimer_tick_to_ms(
                   sl_sleeptimer_get_tick_count() - ota_timer_start)
                 > OTA_SLAVE_PREPARE_TIMEOUT_MS) {
        app_log_error("Slave prepare TIMEOUT. Retrying...\n");
        send_slave_prepare_msg(ota_target_node);
        ota_timer_start = sl_sleeptimer_get_tick_count();
      }
      break;
    }

    case OTA_DISTRIBUTING:
      break;

    case OTA_REQUEST_BOOTLOAD: {
      EmberAfOtaUnicastBootloaderStatus bl_ret =
        emberAfPluginUnicastBootloaderServerInitiateRequestTargetBootload(
          OTA_BOOTLOAD_DELAY_MS,
          ota_image_tag,
          ota_target_node);

      if (bl_ret == EMBER_OTA_UNICAST_BOOTLOADER_STATUS_SUCCESS) {
        app_log_info("Bootload request sent (delay=%dms)\n",
                     OTA_BOOTLOAD_DELAY_MS);
        ota_state = OTA_WAITING_BOOTLOAD;
      } else {
        app_log_error("Bootload request FAILED: 0x%02X\n", bl_ret);
        ota_state = OTA_ERROR;
      }
      break;
    }

    case OTA_WAITING_BOOTLOAD:
      break;

    case OTA_COMPLETE:
      app_log_info("=== OTA COMPLETE for node 0x%04X ===\n", ota_target_node);
      ota_state = OTA_IDLE;
      break;

    case OTA_ERROR:
      app_log_error("=== OTA ERROR. Reset state to IDLE. ===\n");
      ota_state = OTA_IDLE;
      break;

    case OTA_IDLE:
    case OTA_RECEIVING_FW:
    case OTA_FW_READY:
    default:
      break;
  }
}

