/// AP_OBC → Master I2C 명령 코드
#define OBC_CMD_PREPARE       0x01  // 슬롯 erase + 메타데이터 설정
#define OBC_CMD_WRITE_CHUNK   0x02  // GBL 데이터 청크 쓰기
#define OBC_CMD_START_OTA     0x03  // OTA 배포 시작
#define OBC_CMD_STATUS        0x04  // 상태 조회

/// Master → Slave 커스텀 메시지 (Connect 데이터 메시지)
/// Slave가 이 메시지를 받으면 bootloader slot erase + OTA 수신 준비
#define CUSTOM_MSG_PREPARE_OTA   0xF0
#define CUSTOM_MSG_PREPARE_ACK   0xF1
#define CUSTOM_ENDPOINT          0x02  // sensor_sink 엔드포인트와 구분

/// OTA 자동화 타이밍
#define OTA_SLAVE_PREPARE_TIMEOUT_MS   10000  // Slave 준비 대기 (10초)
#define OTA_BOOTLOAD_DELAY_MS          2000   // 부트로드 딜레이

